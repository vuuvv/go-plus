{
  "name": "go-plus",
  "displayName": "Go Plus",
  "description": "VSCode extension skeleton for table-driven Go test run entries.",
  "version": "0.0.1",
  "publisher": "vuuvv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vuuvv/go-plus.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onLanguage:go",
    "workspaceContains:**/*_test.go",
    "onCommand:goPlus.noop",
    "onCommand:goPlus.runTest",
    "onCommand:goPlus.refreshTestTree",
    "onCommand:goPlus.refreshCurrentFileTestTree"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goPlus.noop",
        "title": "Go Plus: No-op"
      },
      {
        "command": "goPlus.runTest",
        "title": "Go Plus: Run Test"
      },
      {
        "command": "goPlus.refreshTestTree",
        "title": "Go Plus: Refresh Test Tree"
      },
      {
        "command": "goPlus.refreshCurrentFileTestTree",
        "title": "Go Plus: Refresh Current File Test Tree"
      }
    ],
    "configuration": {
      "title": "Go Plus",
      "properties": {
        "goPlus.tableTests.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable table-driven test discovery for Go test files."
        },
        "goPlus.tableTests.nameFields": {
          "type": "array",
          "default": [
            "name",
            "desc",
            "caseName",
            "title"
          ],
          "items": {
            "type": "string"
          },
          "description": "Struct fields that can provide stable table-driven subtest names."
        },
        "goPlus.tableTests.showFunctionRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for whole Go test functions."
        },
        "goPlus.tableTests.showCaseRun": {
          "type": "boolean",
          "default": true,
          "description": "Show run entries for resolvable table-driven test cases."
        },
        "goPlus.tableTests.testingApi.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the experimental VSCode Testing API tree for Go Plus table-driven tests."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
